}],"key":"ooF3zYI7j8"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Plot lidar box over ESRI tiles and the SNOTEL station location (if available)\nif 'points' in dir() and points is not None:\n    m = sf.explore(\n        tooltip=False, color=\"grey\", highlight=False, tiles=\"Esri.WorldImagery\",\n        style_kwds={\"opacity\": 0.2}, popup=[\"name\"]\n    )\n    # Add plot showing location of SNOTEL station(s)\n    df = points.to_dataframe()\n    df.explore(m=m, tooltip=[\"name\", \"id\"], color=\"red\", marker_kwds={\"radius\":4})\n    display(m)\nelse:\n    print(\"Skipping map — SNOTEL station data not available (API unreachable).\")\n","key":"kjBUcgPBNT"},{"type":"outputs","id":"suJEKA0Mu4IBf5hpcRT7_","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"Skipping map — SNOTEL station data not available (API unreachable).\n"},"key":"SbZIaFSmVV"}],"key":"wdRPJ8IJiu"}],"key":"fUDUHKFerF"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Now that we know which SNOTEL is in the area, we can query for the data.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"LiStSX6Gjq"}],"key":"iP9rXbV1ZS"}],"key":"YEsG8sS4ZZ"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Define SNOTEL station from FLCF\npt = SnotelPointData(\"1302:AK:SNTL\", \"Creamer's Field\")","key":"ZcOmOTPFIT"},{"type":"outputs","id":"uPpeCfDHxzCHEqlf2sXoF","children":[],"key":"taewqTuXCF"}],"key":"Opc5jJKhgT"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"As with other API requests, we can subset the data with a date range, given as d