ct to SNOTEL API: 500 Server Error: Internal Server Error for url: https://wcc.sc.egov.usda.gov/awdbWebService/services?WSDL\nSkipping live data fetch — likely running in a restricted network environment (e.g., CI).\n"},"key":"uUkfc08xOM"}],"key":"LYtdquioHC"}],"key":"EycZBpwjr4"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Looks like we have a SNOTEL station here! Note the printed output: Metloom returns the station ID number (","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"kKgxsKHulr"},{"type":"inlineCode","value":"1302","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"H5kAH0NlKv"},{"type":"text","value":"), the state it’s in (","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"G8nmcXCQbB"},{"type":"inlineCode","value":"AK","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"u4WMOP9aOS"},{"type":"text","value":"), and the type of weather station (","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"UccLCl5Ysz"},{"type":"inlineCode","value":"SNTL","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"AAHL9blaU9"},{"type":"text","value":").","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"zdpuQVXzhl"}],"key":"wUDLUCBCuH"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"Let’s see where it’s located in Creamer’s Field, relative to the polyon we provided.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"sAKpUdnif2"}],"key":"EEojBjZ0Kc"}],"key":"cUHKtTczpA"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Plot lidar box over ESRI tiles and the SNOTEL station location (if available)\nif 'points' in dir() and points is not None:\n    m = sf.explore(\n        tooltip=False, color=\"grey\", highlight=False, tiles=\"Esri.WorldImagery\",\n        style_kwds={\"opacity\": 0.2}, popup=[\"name\"]\n    )\n    # Add plot showing location of SNOTEL station(s)\n    df = points.to_dataframe()\n    df.explore(m=m, tooltip=[\"name\", \"id\"], color=\"red\", marker_kwds={\"radius\":4})\n    display(m)\nelse:\n    print(\"Skipping map — SNOTEL station data not available (API unreachable).\")\n","key":"DEAECw77Qs"},{"type":"outputs","id":"Nyh0uuvzOuA82W0fqgANF","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"Skipping map — SNOTEL station data not available (API unreachable).\n"},"key":"RcqgXuvQHq"}],"key":"UL5m1bXwPV"}],"key":"UIUy6PFind"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Now that we know which SNOTEL is in the area, we can query for the data.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"WL5wObtdpc"}],"key":"En88aFm0oL"}],"key":"kdCnZJ4Yza"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Define SNOTEL station from FLCF\npt = SnotelPointData(\"1302:AK:SNTL\", \"Creamer's Field\")","key":"MgcgVgTFEi"},{"type":"outputs","id":"iUJP37GCiiIGbUsnZNwki","children":[],"key":"xMFXdnasKo"}],"key":"HYOAGLDb9n"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"As with other API requests, we can subset the data with a date range, given as datetime objects.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"bBBK1Bcira"}],"key":"orGGApkZVm"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"Note here that we are requesting for snow depths on a daily basis. If desired, we could also obtain the hourly data instead, using ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"athlyRwecb"},{"type":"inlineCode","value":"pt.get_hourly_data()","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"fca5TK0IEm"},{"type":"text","value":".","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"q00Rvljm0X"}],"key":"PMrTedoZmN"}],"key":"e1t39N75Cs"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Start and end date of SNOTEL query\nstart_date = datetime(2022, 3, 1)\nend_date = datetime(2023, 4, 1)\n\ncached_path = Path(\"data/snotel_1302_snow_depth.csv\")\n\ntry:\n    df = pt.get_daily_data(start_date, end_date, variables)\nexcept Exception as e:\n    print(f\"Live fetch failed: {e}\")\n    if cached_path.exists():\n        print(\"Loading cached data instead.\")\n        df = pd.read_csv(cached_path, index_col=0, parse_dates=True)\n    else:\n        raise RuntimeError(\"No cached data available and live fetch failed.\") from e","key":"b2mGDzOvDq"},{"type":"outputs","id":"2Cjev4qIBHcKZb9IyyjFE","children":[],"key":"FB3JkrlMHt"}],"key":"xHWmsXzPMW"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"df.head()","key":"GeRVhMxjHy"},{"type":"outputs","id":"FEtzblp9rzeePdcPsIHyq","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":8,"metadata":{},"data":{"text/plain":{"content":"                                                                 geometry  \\\ndatetime                  site                                              \n2022-03-01 09:00:00+00:00 1302:AK:SNTL  POINT Z (-147.73617 64.86534 440)   \n2022-03-02 09:00:00+00:00 1302:AK:SNTL  POINT Z (-147.73617 64.8