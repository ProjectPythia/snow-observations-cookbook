oHl9G"}],"key":"r86jcUmHPJ"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"We will also go ahead and define the variables we want from the station, using ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"hccX6IDObo"},{"type":"inlineCode","value":"SnotelPointData.ALLOWED_VARIABLES","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"G5pi95bRpy"},{"type":"text","value":". Some of the allowed variables include:","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"PxctlisGmg"}],"key":"B7zkS3hPeg"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":4,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"paragraph","children":[{"type":"inlineCode","value":"SNOWDEPTH","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"TTntFCSysv"},{"type":"text","value":": Snow depth, typically in inches.","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"IlDPDl5xFJ"}],"key":"aYLtr44A20"}],"key":"E34OKYpZqU"},{"type":"listItem","spread":true,"position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"paragraph","children":[{"type":"inlineCode","value":"SWE","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"Y1IW5pwIN5"},{"type":"text","value":": Snow water equivalent, typically in inches.","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"EjJwsgfsrM"}],"key":"dO8SCrGPpv"}],"key":"vNXt02weWo"},{"type":"listItem","spread":true,"position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"paragraph","children":[{"type":"inlineCode","value":"PRECIPITATION","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"yeTW9cZFWr"},{"type":"text","value":": Accumulated precipitation, in inches.","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"FdrszRxo6q"}],"key":"rwB7smnYZo"}],"key":"Amx6q5FzX1"},{"type":"listItem","spread":true,"position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"paragraph","children":[{"type":"inlineCode","value":"TMP","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"eJmGppKq0R"},{"type":"text","value":": Air temperature, in degrees Fahrenheit.","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"nTLzKvTn5A"}],"key":"YCOsoMFgm4"}],"key":"wHNls2k1IX"}],"key":"g5Ep7FwVa3"}],"key":"jS574Mlfbm"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Load FLCF lidar box from SnowEx campaigns\nsf_path = Path(\"data/cffl_lidar_box.geojson\").expanduser()\nsf = gpd.read_file(str(sf_path))\nsf[\"name\"] = [\"FLCF\"]\n\n# Load the desired variables for SNOTEL query\nvariables = [SnotelPointData.ALLOWED_VARIABLES.SNOWDEPTH]","key":"jcAnE717xI"},{"type":"outputs","id":"7I7e4uk7ASsaKT5abHmfM","children":[],"key":"d36XCsYTKz"}],"key":"RxPz2wMcfG"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Find SNOTEL stations within polygon with desired variables\ntry:\n    points = SnotelPointData.points_from_geometry(sf, variables)\n    # Print nearby SNOTEL stations within 0.5 degrees of polygon\n    print(SnotelPointData.points_from_geometry(sf, variables, buffer=0.5).points)\nexcept Exception as e:\n    print(f\"Could not connect to SNOTEL API: {e}\")\n    print(\"Skipping live data fetch — likely running in a restricted network environment (e.g., CI).\")","key":"xmXTdc7vZa"},{"type":"outputs","id":"zeXg1SrRT-ivjqwP4blZE","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"[SnotelPointData('1302:AK:SNTL', 'Creamers Field')]\n"},"key":"vVoliXbT2V"}],"key":"WaEInMORx0"}],"key":"x0lpKVNDrx"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Looks like we have a SNOTEL station here! Note the printed output: Metloom returns the station ID number (","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"WjSNtwjOZW"},{"type":"inlineCode","value":"1302","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"okJb0c3WLg"},{"type":"text","value":"), the state it’s in (","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"petdQE59jO"},{"type":"inlineCode","value":"AK","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Rz7vuILgb3"},{"type":"text","value":"), and the type of weather station (","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"ZH8slpAmdc"},{"type":"inlineCode","value":"SNTL","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Lg0VZ5Og0D"},{"type":"text","value":").","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"oXWYgtFY2h"}],"key":"jMx7Ld4MhU"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"Let’s see where it’s located in Creamer’s Field, relative to the polyon we provided.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"o96BDvI9PX"}],"key":"m9EWzqpiF6"}],"key":"nsiGaPPa1g"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Plot lidar box over ESRI tiles and the SNOTEL station location (if available)\nif 'points' in dir() and points is not None:\n    m = sf.explore(\n        tooltip=False, color=\"grey\", highlight=False, tiles=\"Esri.WorldImagery\",\n        style_kwds={\"opacity\": 0.2}, popup=[\"name\"]\n    )\n    # Add plot showing location of SNOTEL station(s)\n    df = points.to_dataframe()\n    df.explore(m=m, tooltip=[\"name\", \"id\"], color=\"red\", marker_kwds={\"radius\":4})\n    display(m)\nelse:\n    print(\"Skipping map — SNOTEL station data not available (API unreachable).\")\n","key":"Ce0sNHlHYY"},{"type":"outputs","id":"Ttcrlpc4RTeWplm-gs9lW","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<folium.folium.Map at 0x7fc9bddd0980>","content_type":"text/plain"},"text/html":{"content":"<div style=\"width:100%;\"><div style=\"position:relative;width:100%;height:0;padding-bottom:60%;\"><span style=\"color:#565656\">Make this Notebook Trusted to load map: File -> Trust Notebook</span><iframe srcdoc=\"&lt;!DOCTYPE html&gt;\n&lt;html&gt;\n&lt;head&gt;\n    \n    &lt;meta http-equiv=&quot;content-type&quot; content=&quot;text/html; charset=UTF-8&quot; /&gt;\n    &lt;script src=&quot;https://cdn.jsdelivr.net/npm/leaflet@1.9.3/dist/leaflet.js&quot;&gt;&lt;/script&gt;\n    &lt;script src=&quot;https://code.jquery.com/jquery-3.7.1.min.js&quot;&gt;&lt;/script&gt;\n    &lt;script src=&quot;https://cdn.jsdelivr.net/npm/bootstrap@5.2.2/dist/js/bootstrap.bundle.min.js&quot;&gt;&lt;/script&gt;\n    &lt;script src=&quot;https://cdnjs.cloudflare.com/ajax/libs/Leaflet.awesome-markers/2.0.2/leaflet.awesome-markers.js&quot;&gt;&lt;/script&gt;\n    &lt;link rel=&quot;stylesheet&quot; href=&quot;https://cdn.jsdelivr.net/npm/leaflet@1.9.3/dist/leaflet.css&quot;/&gt;\n    &lt;link rel=&quot;stylesheet&quot; href=&quot;https://cdn.jsdelivr.net/npm/bootstrap@5.2.2/dist/css/bootstrap.min.css&quot;/&gt;\n    &lt;link rel=&quot;stylesheet&quot; href=&quot;https://netdna.bootstrapcdn.com/bootstrap/3.0.0/css/bootstrap-glyphicons.css&quot;/&gt;\n    &lt;link rel=&quot;stylesheet&quot; href=&quot;https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free