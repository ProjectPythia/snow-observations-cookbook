ey":"pEAphg8tbI"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"We will also go ahead and define the variables we want from the station, using ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"H0RE0e4oDF"},{"type":"inlineCode","value":"SnotelPointData.ALLOWED_VARIABLES","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"OtniRIkLkO"},{"type":"text","value":". Some of the allowed variables include:","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"MkDmlzHYq6"}],"key":"GAxMzyCjNq"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":4,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"paragraph","children":[{"type":"inlineCode","value":"SNOWDEPTH","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"c7OvbZgubK"},{"type":"text","value":": Snow depth, typically in inches.","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"tWdcoiqBRr"}],"key":"Wz91Z4i458"}],"key":"G9r7MoJLYr"},{"type":"listItem","spread":true,"position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"paragraph","children":[{"type":"inlineCode","value":"SWE","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"dxD4DRCLWk"},{"type":"text","value":": Snow water equivalent, typically in inches.","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"eYwvkgMyq8"}],"key":"a2i3SExJ6C"}],"key":"HrCwgWLJnn"},{"type":"listItem","spread":true,"position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"paragraph","children":[{"type":"inlineCode","value":"PRECIPITATION","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"TQUWTLKp5C"},{"type":"text","value":": Accumulated precipitation, in inches.","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"chEyhhbRb1"}],"key":"mMTYtVbcSl"}],"key":"A0tM36eIxC"},{"type":"listItem","spread":true,"position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"paragraph","children":[{"type":"inlineCode","value":"TMP","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"AwbG0aQUCd"},{"type":"text","value":": Air temperature, in degrees Fahrenheit.","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"qhqPB6vZVF"}],"key":"jLkICUKktc"}],"key":"q01cJfNhmR"}],"key":"xSRIchhwtR"}],"key":"AH244ms7w6"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Load FLCF lidar box from SnowEx campaigns\nsf_path = Path(\"data/cffl_lidar_box.geojson\").expanduser()\nsf = gpd.read_file(str(sf_path))\nsf[\"name\"] = [\"FLCF\"]\n\n# Load the desired variables for SNOTEL query\nvariables = [SnotelPointData.ALLOWED_VARIABLES.SNOWDEPTH]","key":"Kt7Bkle72b"},{"type":"outputs","id":"C9FvKSuig0Hr4T85hTW2b","children":[],"key":"eLKAoarl2U"}],"key":"mpyVhIJ8NT"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Find SNOTEL stations within polygon with desired variables\ntry:\n    points = SnotelPointData.points_from_geometry(sf, variables)\n    # Print nearby SNOTEL stations within 0.5 degrees of polygon\n    print(SnotelPointData.points_from_geometry(sf, variables, buffer=0.5).points)\nexcept Exception as e:\n    print(f\"Could not connect to SNOTEL API: {e}\")\n    print(\"Skipping live data fetch — likely running in a restricted network environment (e.g., CI).\")","key":"iYWv0imJql"},{"type":"outputs","id":"yXgTT2a_WyXx5TRBYdm7p","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"[SnotelPointData('1302:AK:SNTL', 'Creamers Field')]\n"},"key":"eaSgiSM7um"}],"key":"tPlW28PJLi"}],"key":"Ox00NJQJlp"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Looks like we have a SNOTEL station here! Note the printed output: Metloom returns the station ID number (","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"JK50nlEZ1y"},{"type":"inlineCode","value":"1302","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"lUSBJPiwyU"},{"type":"text","value":"), the state it’s in (","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"ZB6O41ZpmX"},{"type":"inlineCode","value":"AK","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"S5WDlrD5bh"},{"type":"text","value":"), and the type of weather station (","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"cJIfvkK8LN"},{"type":"inlineCode","value":"SNTL","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"ZavAszS2Kg"},{"type":"text","value":").","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"ecfUdpsPAl"}],"key":"g2Up6iwK8S"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"Let’s see where it’s located in Creamer’s Field, relative to the polyon we provided.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"qpbPd6RgFv"}],"key":"f5gztaVLFH"}],"key":"EYMCWLDBOi"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Plot lidar box over ESRI tiles and the SNOTEL station location (if available)\nif 'points' in dir() and points is not None:\n    m = sf.explore(\n        tooltip=False, color=\"grey\", highlight=False, tiles=\"Esri.WorldImagery\",\n        style_kwds={\"opacity\": 0.2}, popup=[\"name\"]\n    )\n    # Add plot showing location of SNOTEL station(s)\n    df = points.to_dataframe()\n    df.explore(m=m, tooltip=[\"name\", \"id\"], color=\"red\", marker_kwds={\"radius\":4})\n    display(m)\nelse:\n    print(\"Skipping map — SNOTEL station data not available (API unreachable).\")\n","key":"LcbPKLfl8P"},{"type":"outputs","id":"RrHJF2z9dL5V1W_riGQX1","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<folium.folium.Map at 0x7f0aa3d49160>","content_type":"text/plain"},"text/html":{"content":"<div style=\"width:100%;\"><div style=\"position:relative;width:100%;height:0;padding-bottom:60%;\"><span style=\"color:#565656\">Make this Notebook Trusted to load map: File -> Trust Notebook</span><iframe srcdoc=\"&lt;!DOCTYPE html&gt;\n&lt;html&gt;\n&lt;head&gt;\n    \n    &lt;meta http-equiv=&quot;content-type&quot; content=&quot;text/html; charset=UTF-8&quot; /&gt;\n    &lt;script src=&quot;https://cdn.jsdelivr.net/npm/leaflet@1.9.3/dist/leaflet.js&quot;&gt;&lt;/script&gt;\n    &lt;script src=&quot;https://code.jquery.com/jquery-3.7.1.min.js&quot;&gt;&lt;/script&gt;\n    &lt;script src=&quot;https://cdn.jsdelivr.net/npm/bootstrap@5.2.2/dist/js/bootstrap.bundle.min.js&quot;&gt;&lt;/script&gt;\n    &lt;script src=&quot;https://cdnjs.cloudflare.com/ajax/libs/Leaflet.awesome-markers/2.0.2/leaflet.awesome-markers.js&quot;&gt;&lt;/script&gt;\n    &lt;link rel=&quot;stylesheet&quot; href=&quot;https://cdn.jsdelivr.net/npm/leaflet@1.9.3/dist/leaflet.css&quot;/&gt;\n    &lt;link rel=&quot;stylesheet&quot; href=&quot;https://cdn.jsdelivr.net/npm/bootstrap@5.2.2/dist/css/bootstrap.min.css&quot;/&gt;\n    &lt;link rel=&quot;stylesheet&quot; href=&quot;https://netdna.bootstrapcdn.com/bootstrap/3.0.0/css/bootstrap-glyphicons.css&quot;/&gt;\n    &lt;link rel=&quot;stylesheet&quot; href=&quot;https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.2.0/css/