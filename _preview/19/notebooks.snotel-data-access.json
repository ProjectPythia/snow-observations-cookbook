ZaGSxh"}],"key":"k91w87HeUN"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"We will also go ahead and define the variables we want from the station, using ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"oWJ9Hut1iL"},{"type":"inlineCode","value":"SnotelPointData.ALLOWED_VARIABLES","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"jrLKc6IoDE"},{"type":"text","value":". Some of the allowed variables include:","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"QOgORNVgC2"}],"key":"FfVy9R2i6L"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":4,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"paragraph","children":[{"type":"inlineCode","value":"SNOWDEPTH","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"iuAT4aYs3D"},{"type":"text","value":": Snow depth, typically in inches.","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"owbZ8zliEa"}],"key":"bg6jZ5Hm1E"}],"key":"eka2wTMGXv"},{"type":"listItem","spread":true,"position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"paragraph","children":[{"type":"inlineCode","value":"SWE","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"w0dFbmD335"},{"type":"text","value":": Snow water equivalent, typically in inches.","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"jMbgyUcZxe"}],"key":"H3gvI9U0IE"}],"key":"fr0c9u2PSh"},{"type":"listItem","spread":true,"position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"paragraph","children":[{"type":"inlineCode","value":"PRECIPITATION","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"JVvTvKr35f"},{"type":"text","value":": Accumulated precipitation, in inches.","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"hmxbywd3nP"}],"key":"BawFCjaLuk"}],"key":"aFxCHdtUOH"},{"type":"listItem","spread":true,"position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"paragraph","children":[{"type":"inlineCode","value":"TMP","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"xdkt8dCxIJ"},{"type":"text","value":": Air temperature, in degrees Fahrenheit.","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"DLl1UsRwnf"}],"key":"BtcJxuXAKm"}],"key":"FQiMPvYHCg"}],"key":"AQgBNuzUEx"}],"key":"V0CLUteolv"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Load FLCF lidar box from SnowEx campaigns\nsf_path = Path(\"data/cffl_lidar_box.geojson\").expanduser()\nsf = gpd.read_file(str(sf_path))\nsf[\"name\"] = [\"FLCF\"]\n\n# Load the desired variables for SNOTEL query\nvariables = [SnotelPointData.ALLOWED_VARIABLES.SNOWDEPTH]","key":"KvJFcaeGDU"},{"type":"outputs","id":"ED61DyYMcG21Nphf0-hfn","children":[],"key":"UuKDWhG4Ao"}],"key":"OmjV1APLEj"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Find SNOTEL stations within polygon with desired variables\ntry:\n    points = SnotelPointData.points_from_geometry(sf, variables)\n    # Print nearby SNOTEL stations within 0.5 degrees of polygon\n    print(SnotelPointData.points_from_geometry(sf, variables, buffer=0.5).points)\nexcept Exception as e:\n    print(f\"Could not connect to SNOTEL API: {e}\")\n    print(\"Skipping live data fetch — likely running in a restricted network environment (e.g., CI).\")","key":"yc3bVyqjNx"},{"type":"outputs","id":"aXw0pG_nQWXD1D8ZZoBlr","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"[SnotelPointData('1302:AK:SNTL', 'Creamers Field')]\n"},"key":"CBPvIiCw9Z"}],"key":"jVwGaXxTS4"}],"key":"KHB7F1TNNR"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Looks like we have a SNOTEL station here! Note the printed output: Metloom returns the station ID number (","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"cTC8cOtJhv"},{"type":"inlineCode","value":"1302","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"unerHqBN1H"},{"type":"text","value":"), the state it’s in (","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"GJPf8j6DqY"},{"type":"inlineCode","value":"AK","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"BESfL6tzR2"},{"type":"text","value":"), and the type of weather station (","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"cmZI3PQZcO"},{"type":"inlineCode","value":"SNTL","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Au3Aj15lGC"},{"type":"text","value":").","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"MzDqX1oX1p"}],"key":"Zr05Oyn4np"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"Let’s see where it’s located in Creamer’s Field, relative to the polyon we provided.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"Y7LFPF2uWz"}],"key":"R0RHn6vKHN"}],"key":"UmKz9mxXjo"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Plot lidar box over ESRI tiles and the SNOTEL station location (if available)\nif 'points' in dir() and points is not None:\n    m = sf.explore(\n        tooltip=False, color=\"grey\", highlight=False, tiles=\"Esri.WorldImagery\",\n        style_kwds={\"opacity\": 0.2}, popup=[\"name\"]\n    )\n    # Add plot showing location of SNOTEL station(s)\n    df = points.to_dataframe()\n    df.explore(m=m, tooltip=[\"name\", \"id\"], color=\"red\", marker_kwds={\"radius\":4})\n    display(m)\nelse:\n    print(\"Skipping map — SNOTEL station data not available (API unreachable).\")\n","key":"qIWNAqfLJ6"},{"type":"outputs","id":"hXUZ40mY4opIxgot6yQbO","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<folium.folium.Map at 0x7fbdea4b1400>","content_type":"text/plain"},"text/html":{"content":"<div style=\"width:100%;\"><div style=\"position:relative;width:100%;height:0;padding-bottom:60%;\"><span style=\"color:#565656\">Make this Notebook Trusted to load map: File -> Trust Notebook</span><iframe srcdoc=\"&lt;!DOCTYPE html&gt;\n&lt;html&gt;\n&lt;head&gt;\n    \n    &lt;meta http-equiv=&quot;content-type&quot; content=&quot;text/html; charset=UTF-8&quot; /&gt;\n    &lt;script src=&quot;https://cdn.jsdelivr.net/npm/leaflet@1.9.3/dist/leaflet.js&quot;&gt;&lt;/script&gt;\n    &lt;script src=&quot;https://code.jquery.com/jquery-3.7.1.min.js&quot;&gt;&lt;/script&gt;\n    &lt;script src=&quot;https://cdn.jsdelivr.net/npm/bootstrap@5.2.2/dist/js/bootstrap.bundle.min.js&quot;&gt;&lt;/script&gt;\n    &lt;script src=&quot;https://cdnjs.cloudflare.com/ajax/libs/Leaflet.awesome-markers/2.0.2/leaflet.awesome-markers.js&quot;&gt;&lt;/script&gt;\n    &lt;link rel=&quot;stylesheet&quot; href=&quot;https://cdn.jsdelivr.net/npm/leaflet@1.9.3/dist/leaflet.css&quot;/&gt;\n    &lt;link rel=&quot;stylesheet&quot; href=&quot;https://cdn.jsdelivr.net/npm/bootstrap@5.2.2/dist/css/bootstrap.min.css&quot;/&gt;\n    &lt;link rel=&quot;stylesheet&quot; href=&quot;https://netdna.bootstrapcdn.com/bootstrap/3.0.0/css/bootstrap-glyphicons.css&quot;/&gt;\n    &lt;link rel=&quot;stylesheet&quot; href=&quot;https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-fre